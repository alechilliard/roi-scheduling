# ─────────────────────────────────────────────
# The ROI Guys — Scheduling App Environment
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it's already in .gitignore).
# ─────────────────────────────────────────────

# ── Google OAuth (for Calendar sync) ──────────────────────────
# Get this from Google Cloud Console → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=YOUR_CLIENT_ID_HERE.apps.googleusercontent.com

# ── Google Maps (for address autocomplete) ─────────────────────
# Get this from Google Cloud Console → APIs & Services → Credentials
VITE_GOOGLE_MAPS_KEY=YOUR_MAPS_API_KEY_HERE

# ── Google Calendar IDs ────────────────────────────────────────
# Find each in Google Calendar → Settings → [Calendar name] → "Calendar ID"
# It looks like: abc123@group.calendar.google.com
VITE_GCAL_SHOWINGS=YOUR_SHOWINGS_CALENDAR_ID
VITE_GCAL_MAIN=YOUR_MAIN_CALENDAR_ID
VITE_GCAL_CLOSINGS=YOUR_CLOSINGS_CALENDAR_ID
VITE_GCAL_TIMEOFF=YOUR_TIMEOFF_CALENDAR_ID

# ── Team Google email addresses (for calendar invites) ─────────
VITE_EMAIL_JAMES=james@example.com
VITE_EMAIL_BEN=ben@example.com
VITE_EMAIL_DAVIS=davis@example.com
